import {Palette} from "palette.slint";
import { MetronomePanel } from "metronome_panel.slint";
import { ControlPanel } from "control_panel.slint";
import {MetronomeUnit} from "metronome_unit.slint";
import { UnitPanel } from "unit_panel.slint";

import { ButtonLogic } from "logic.slint";
export { ButtonLogic }


export component MainWindow inherits Window {

    in property <bool> is-android: true;
    in-out property <int> actual-beat: 1;

    in-out property <[MetronomeUnit]> metronome-model;
    in-out property <int> index: -1;
    in-out property <int> repetitons-left;

    background: Palette.background;
    default-font-size: 20px;
    
    VerticalLayout {
        width: 100%;
        padding-top: 40px;
        spacing: 15px;
        padding-left: 15px;
        padding-right: 15px;
        padding-bottom: is-android ? 48px : 34px;
        VerticalLayout {
            spacing: 15px;
            MetronomePanel {
                numerator: index >= 0 ? metronome-model[index].numerator : 4;
                denominator: index >= 0 ? metronome-model[index].denominator : 4;
                tempo: index >= 0 ? metronome-model[index].tempo : 120;
                actual-beat: actual-beat;
                
            }
            control := 
            ControlPanel {

            }
        }
        
        UnitPanel {
            model: root.metronome-model;
        }
    }
}

